|   |   +-- user_postgres_test.go        # Integration tests
|   |-- handler/                         # HTTP handlers
|   |   |-- user_handler.go
|   |   |-- middleware/auth.go
|   |   +-- router.go
|   |-- grpc/                            # gRPC handlers
|   |   |-- pb/<module>/                 # Generated — DO NOT edit
|   |   |-- <service>_server.go
|   |   +-- server.go
|   +-- infra/
|       |-- postgres.go
|       |-- redis.go
|       +-- config.go
|-- pkg/logger/ | pkg/validator/
